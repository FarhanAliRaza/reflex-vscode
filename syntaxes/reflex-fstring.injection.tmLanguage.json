{
  "$comment": "GENERATED by syntaxes/generate.py \u2014 do not edit by hand.",
  "scopeName": "reflex-fstring.injection",
  "injectionSelector": "L:meta.embedded.block.javascript.fstring, L:meta.embedded.block.javascriptreact.fstring, L:meta.embedded.block.typescript.fstring, L:meta.embedded.block.css.fstring, L:meta.embedded.block.html.fstring, L:meta.embedded.inline.css.fstring, L:meta.embedded.inline.tailwind-classes.fstring",
  "patterns": [
    {
      "match": "\\{\\{|\\}\\}",
      "name": "constant.character.escape.python"
    },
    {
      "begin": "\\{",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.template-expression.begin.python"
        }
      },
      "end": "\\}",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.template-expression.end.python"
        }
      },
      "name": "meta.embedded.python",
      "contentName": "source.python",
      "patterns": [
        {
          "include": "source.python"
        }
      ]
    }
  ]
}
